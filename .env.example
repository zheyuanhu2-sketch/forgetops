# ForgetOps application settings. Never commit real credentials.
FORGETOPS_ENV=development
FORGETOPS_DEMO_MODE=true

# Local DataHub Core defaults. Use a dedicated token when auth is enabled.
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_GMS_TOKEN=
DATAHUB_COMPOSE_PROJECT_NAME=forgetops-datahub
DATAHUB_TELEMETRY_ENABLED=false
TOOLS_IS_MUTATION_ENABLED=false

# Optional OpenAI-compatible model provider. Deterministic planning works without it.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
